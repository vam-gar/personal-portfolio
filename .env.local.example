# Contact form delivery (Formspree).
# 1. Create a free form at https://formspree.io and set its destination email
#    to vagarlapati@gmail.com.
# 2. Copy this file to `.env.local` and paste your form's endpoint URL below.
# 3. Restart `npm run dev` so Next.js picks up the new env var.
NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/your-form-id

# Portfolio-Bot (Gemini API).
# Get a free key at https://aistudio.google.com/app/apikey
# This is server-only (no NEXT_PUBLIC_ prefix) so it never reaches the browser.
GEMINI_API_KEY=your-gemini-api-key
